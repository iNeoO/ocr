{
  "name": "ocr",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "backend:dev": "dotenv -e .env -- pnpm --filter @ocr/backend dev",
    "frontend:dev": "dotenv -e .env -- pnpm --filter @ocr/frontend dev",
    "cleanup-process-worker:dev": "dotenv -e .env -- pnpm --filter @ocr/cleanup-process-worker dev",
    "split-pdf-worker:dev": "dotenv -e .env -- pnpm --filter @ocr/split-pdf-worker dev",
    "transcribe-jpg-worker:dev": "dotenv -e .env -- pnpm --filter @ocr/transcribe-jpg-worker dev",
    "post-process-page-worker:dev": "dotenv -e .env -- pnpm --filter @ocr/post-process-page-worker dev",
    "workers:dev": "concurrently \"pnpm split-pdf-worker:dev\" \"pnpm transcribe-jpg-worker:dev\" \"pnpm post-process-page-worker:dev\" \"pnpm cleanup-process-worker:dev\"",
    "dev": "concurrently \"pnpm backend:dev\" \"pnpm frontend:dev\" \"pnpm workers:dev\"",
    "predev": "pnpm build:runtime",
    "build:runtime": "pnpm --filter @ocr/common build && pnpm --filter @ocr/infra build && pnpm --filter @ocr/db build && pnpm --filter @ocr/post-process-page-worker build && pnpm --filter @ocr/transcribe-jpg-worker build && pnpm --filter @ocr/split-pdf-worker build && pnpm --filter @ocr/services build && pnpm --filter @ocr/cleanup-process-worker build && pnpm --filter @ocr/backend build",
    "build": "pnpm build:runtime && pnpm --filter @ocr/scripts build && pnpm --filter @ocr/frontend build",
    "backend:build": "dotenv -e .env -- pnpm --filter @ocr/backend build",
    "db:build": "dotenv -e .env -- pnpm --filter @ocr/db build",
    "db:drop": "dotenv -e .env -- pnpm --filter @ocr/db drop",
    "db:pull": "dotenv -e .env -- pnpm --filter @ocr/db pull",
    "db:push": "dotenv -e .env -- pnpm --filter @ocr/db push",
    "db:generate": "dotenv -e .env -- pnpm --filter @ocr/db generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @ocr/db migrate",
    "db:deploy": "dotenv -e .env -- pnpm --filter @ocr/db deploy",
    "db:reset": "dotenv -e .env -- pnpm --filter @ocr/db reset",
    "scripts:clean-processes": "dotenv -e .env -- pnpm --filter @ocr/scripts clean-processes",
    "scripts:generate-openapi": "pnpm --filter @ocr/scripts generate-openapi",
    "scripts:serve-openapi": "pnpm --filter @ocr/scripts serve-openapi",
    "lint": "pnpm -r run lint"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "dotenv-cli": "^11.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
