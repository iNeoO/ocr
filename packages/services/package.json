{
  "name": "@ocr/services",
  "type": "module",
  "scripts": {
    "dev:services": "tsx watch --clear-screen=false src/index.ts",
    "test": "vitest",
    "lint": "biome check",
    "build": "rm -rf dist && tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.888.0",
    "@better-auth/redis-storage": "^1.6.0",
    "@ocr/common": "workspace:*",
    "@ocr/db": "workspace:*",
    "@ocr/infra": "workspace:*",
    "@ocr/split-pdf-worker": "workspace:*",
    "@ocr/transcribe-jpg-worker": "workspace:*",
    "@ocr/post-process-page-worker": "workspace:*",
    "better-auth": "^1.6.0",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.10.1",
    "jszip": "^3.10.1",
    "pdf-parse": "^2.4.5",
    "resend": "^4.7.0",
    "tesseract.js": "^6.0.1"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./auth/auth.service": {
      "types": "./src/auth/auth.service.ts",
      "default": "./dist/auth/auth.service.js"
    },
    "./files/files.service": {
      "types": "./src/files/files.service.ts",
      "default": "./dist/files/files.service.js"
    },
    "./process/process.service": {
      "types": "./src/process/process.service.ts",
      "default": "./dist/process/process.service.js"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
