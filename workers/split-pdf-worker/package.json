{
  "name": "@ocr/split-pdf-worker",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "start": "node dist/index.js",
    "lint": "biome check",
    "build": "rm -rf dist && tsc"
  },
  "dependencies": {
    "amqplib": "catalog:",
    "@ocr/db": "workspace:*",
    "@ocr/infra": "workspace:*",
    "@ocr/services": "workspace:*",
    "@ocr/transcribe-jpg-worker": "workspace:*",
    "zod": "catalog:"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      }
    },
    "./publisher": {
      "import": {
        "types": "./src/publisher.ts",
        "default": "./src/publisher.ts"
      }
    }
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/amqplib": "catalog:",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
